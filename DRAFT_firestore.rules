rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // 2. Validation Blueprints
    function isValidSecurityEvent(data) {
      return data.keys().hasAll(['type', 'description', 'confidence', 'imageUrl', 'timestamp'])
        && data.keys().size() == 5
        && data.type in ['shoplifting', 'fall', 'suspicious', 'error', 'normal']
        && data.description is string && data.description.size() <= 2000
        && data.confidence is number && data.confidence >= 0 && data.confidence <= 1
        && data.imageUrl is string && data.imageUrl.size() <= 1048576 
        && data.timestamp == request.time;
    }

    // 1. The "Master Gate"
    match /users/{userId}/events/{eventId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidSecurityEvent(incoming());
      // Audit Integrity: No updates or deletes allowed for reported incidents.
    }
    
    // Connectivity test path
    match /test/connection {
      allow get: if true;
    }
  }
}
